{
  "manifest_version": 3,
  "name": "Skill Bridge",
  "version": "1.2.0",
  "description": "Bridge local Agent Skills with IDE coding assistants and Web Chat UIs.",
  "permissions": [
    "storage",
    "scripting",
    "nativeMessaging"
  ],
  "optional_host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://www.deepseek.com/*",
    "https://chat.qwen.ai/*",
    "https://chat.z.ai/*",
    "https://grok.com/*",
    "https://kimi.moonshot.cn/*",
    "https://chat.mistral.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://huggingface.co/chat/*",
    "https://huggingface.co/*",
    "https://poe.com/*",
    "https://groq.com/*",
    "https://www.phind.com/*",
    "https://phind.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://chatglm.cn/*",
        "https://chat.z.ai/*",
        "https://grok.com/*",
        "https://kimi.moonshot.cn/*",
        "https://chat.mistral.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://huggingface.co/chat/*",
        "https://huggingface.co/*",
        "https://poe.com/*",
        "https://groq.com/*",
        "https://www.phind.com/*",
        "https://phind.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}